generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Estado {
  ACTIVO
  INACTIVO
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  ROLE_SELECTED
  TOKEN_REFRESHED
  TOKEN_REVOKED
  LOGOUT
  UNAUTHORIZED_ATTEMPT
}

model User {
  id                String         @id @default(uuid())
  nombre            String
  email             String         @unique
  passwordHash      String
  estado            Estado         @default(ACTIVO)
  fechaCreacion     DateTime       @default(now())
  fechaActualizacion DateTime      @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  userRoles         UserRole[]
  refreshTokens     RefreshToken[]
  tokenRevocations  TokenRevocation[]
  auditLogs         AuditLog[]
}

model Role {
  id                String           @id @default(uuid())
  nombre            String           @unique
  descripcion       String?
  estado            Estado           @default(ACTIVO)
  fechaCreacion     DateTime         @default(now())
  fechaActualizacion DateTime        @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  userRoles         UserRole[]
  roleModules       RoleModule[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
}

model UserRole {
  id                String      @id @default(uuid())
  userId            String
  roleId            String
  estado            Estado      @default(ACTIVO)
  fechaCreacion     DateTime    @default(now())
  fechaActualizacion DateTime   @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  user              User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  role              Role        @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Module {
  id                String       @id @default(uuid())
  nombre            String       @unique
  descripcion       String?
  estado            Estado       @default(ACTIVO)
  fechaCreacion     DateTime     @default(now())
  fechaActualizacion DateTime    @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  roleModules       RoleModule[]
  menus             Menu[]
}

model RoleModule {
  id                String       @id @default(uuid())
  roleId            String
  moduleId          String
  estado            Estado       @default(ACTIVO)
  fechaCreacion     DateTime     @default(now())
  fechaActualizacion DateTime    @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  role              Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  module            Module       @relation(fields: [moduleId], references: [id], onDelete: Restrict)

  @@unique([roleId, moduleId])
  @@index([roleId])
  @@index([moduleId])
}

model Menu {
  id                String       @id @default(uuid())
  nombre            String
  url               String?
  moduleId          String
  parentId          String?
  estado            Estado       @default(ACTIVO)
  fechaCreacion     DateTime     @default(now())
  fechaActualizacion DateTime    @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  module            Module       @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  parent            Menu?        @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children          Menu[]       @relation("MenuHierarchy")

  @@index([moduleId])
  @@index([parentId])
}

model RefreshToken {
  id                String      @id @default(uuid())
  userId            String
  roleId            String
  tokenHash         String
  expiracion        DateTime
  revocado          Boolean     @default(false)
  reemplazadoPor    String?
  estado            Estado      @default(ACTIVO)
  fechaCreacion     DateTime    @default(now())
  fechaActualizacion DateTime   @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  user              User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  role              Role        @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([roleId])
  @@index([expiracion])
}

model TokenRevocation {
  id                String      @id @default(uuid())
  jti               String      @unique
  userId            String?
  reason            String?
  expiracion        DateTime
  estado            Estado      @default(ACTIVO)
  fechaCreacion     DateTime    @default(now())
  fechaActualizacion DateTime   @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jti])
  @@index([userId])
  @@index([expiracion])
}

model AuditLog {
  id                String      @id @default(uuid())
  userId            String?
  roleId            String?
  action            AuditAction
  detail            String?
  ipAddress         String?
  userAgent         String?
  estado            Estado      @default(ACTIVO)
  fechaCreacion     DateTime    @default(now())
  fechaActualizacion DateTime   @updatedAt
  creadoPor         String?
  actualizadoPor    String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  role              Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([roleId])
  @@index([action])
}
